# Este archivo .gitignore está optimizado para proyectos de Unity
# Evita subir archivos innecesarios al repositorio

# =============== #
# Unity generated #
# =============== #
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/

# MemoryCaptures puede aparecer cuando uses el Profiler
/[Mm]emoryCaptures/

# Configuraciones de caché y compilación
/[Aa]ssets/AssetStoreTools*
*.stackdump

# ===================================== #
# Visual Studio / Rider / VS Code      #
# ===================================== #
.vs/
.vscode/
.idea/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# ===================================== #
# Unity3D generated meta files         #
# ===================================== #
*.pidb.meta
*.pdb.meta
*.mdb.meta
*.meta

# ===================================== #
# Unity3D generated file on crash      #
# ===================================== #
sysinfo.txt

# ===================================== #
# Builds                                #
# ===================================== #
*.apk
*.aab
*.unitypackage
*.app

# ===================================== #
# Crashlytics generated file            #
# ===================================== #
crashlytics-build.properties

# ===================================== #
# Packed Addressables                   #
# ===================================== #
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*

# ===================================== #
# Temporary auto-generated Android      #
# ===================================== #
/[Aa]ssets/[Pp]lugins/[Aa]ndroid/*.meta

# ===================================== #
# Local files                           #
# ===================================== #
*.log
*.cache

# ===================================== #
# OS generated                          #
# ===================================== #
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# ===================================== #
# Plastic SCM                           #
# ===================================== #
.plastic/

# ===================================== #
# Autodesk                              #
# ===================================== #
*.fbx.meta

# ===================================== #
# JetBrains Rider                       #
# ===================================== #
.idea/
*.sln.iml

# ===================================== #
# Archivos personales del proyecto     #
# ===================================== #
# Descomentar si tienes archivos que no quieres subir
# /[Aa]ssets/[Tt]esting/
# /[Aa]ssets/[Dd]raft/
