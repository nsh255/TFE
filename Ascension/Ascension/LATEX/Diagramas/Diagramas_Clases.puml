@startuml Ascension_Class_Diagram
!theme plain

package "Datos (ScriptableObject)" {
    class PlayerClass {
        - className: string
        - maxHealth: int
        - speed: float
        - startingWeaponData: WeaponData
    }

    class EnemyData {
        - enemyName: string
        - maxHealth: int
        - damage: int
        - speed: float
        - sprite: Sprite
        - enemyCost: int
    }

    class WeaponData {
        - weaponName: string
        - damage: int
        - weaponPrefab: GameObject
        - rarity: int
    }
}

package "Jugador" {
    class PlayerController {
        - animator: Animator
        - rigidbody: Rigidbody2D
        - velocity: Vector3
        - isInvulnerable: bool
        - playerClass: PlayerClass
        - speed: float
        - baseSpeed: float
        - weaponOffset: Vector3
        + Initialize()
        + TakeDamage(amount: int)
        + Die()
        + Dodge()
        + ApplySpeedMultiplier(multiplier: float)
        + Update()
        + Move(direction: Vector2)
    }

    class PlayerHealth {
        - currentHealth: int
        - maxHealth: int
        - lastDamageTime: float
        - invulnerabilityCooldown: float
        + Initialize()
        + TakeDamage(amount: int)
        + Heal(amount: int)
        + Die()
        + IsAlive(): bool
    }

    class PlayerSpawner {
        - playerPrefab: GameObject
        - spawn: Transform
        - player: GameObject
        + SpawnPlayer()
    }
}

package "Enemigos" {
    class Enemy {
        - enemyData: EnemyData
        - currentHealth: int
        - isDead: bool
        - player: Transform
        - playerController: PlayerController
        - spriteRenderer: SpriteRenderer
        - rb: Rigidbody2D
        - animator: Animator
        - damageRate: float
        - contactDamageGraceSeconds: float
        - aiGraceSeconds: float
        - tileSpeedMultiplier: float
        # IsAIEnabled: bool
        # Awake()
        # Start()
        + TakeDamage(amount: int)
        # Die()
        # Update()
        # UpdateFacingToPlayer()
        + SetEnemyData(data: EnemyData)
    }

    class BossController {
        - maxHealth: int
        - currentHealth: int
        - phase: int
        - projectileSpawnPoint: Transform
        - player: Transform
        - attackPattern: float
        # Start()
        # Update()
        + ChangePhase(newPhase: int)
        + AttackPattern1()
        + AttackPattern2()
    }

    class EnemyManager {
        - spawnPoints: List<Transform>
        - maxEnemies: int
        - currentEnemies: List<Enemy>
        - enemyPrefabs: List<GameObject>
        - spawnRadius: float
        - costBudget: int
        + SpawnEnemy(data: EnemyData, position: Vector3)
        + CleanupRoom()
        + SelectWeightedEnemy(): EnemyData
        + IsSpawnLocationSafe(position: Vector3): bool
    }

    class EnemyProjectile {
        - damage: int
        - lifetime: float
        - playerLayer: LayerMask
        - desiredPixelSize: int
        + Start()
        + OnTriggerEnter2D(collision: Collider2D)
        + OnCollisionEnter2D(collision: Collision2D)
    }

    class EnemyProjectileSpawner {
        - projectilePrefab: GameObject
        - spawnPoint: Transform
        - fireRate: float
        + SpawnProjectile(direction: Vector2)
    }

    class EnemyTileEffectReceiver {
        - tileSpeedMultiplier: float
        + ApplyTileEffect(effect: TileEffect)
    }
}

package "Armas" {
    class Weapon {
        - spriteRenderer: SpriteRenderer
        - weaponData: WeaponData
        - camera: Camera
        - isInitialized: bool
        - attackWhileHeld: bool
        # Start()
        + Initialize()
        + Attack()
        # OrbitAroundPlayer()
        # RotateTowardsMouse()
        # Update()
    }

    class MeleeWeapon {
        - attackRange: float
        - attackCooldown: float
        - lastAttackTime: float
        + Attack()
        - DetectEnemiesInRange(): Enemy[]
    }

    class RangedWeapon {
        - projectilePrefab: GameObject
        - fireRate: float
        - lastShotTime: float
        + Attack()
        - CreateProjectile(direction: Vector2)
    }

    class Projectile {
        - damage: int
        - speed: float
        - lifetime: float
        - desiredPixelSize: int
        - rb: Rigidbody2D
        + Start()
        + OnTriggerEnter2D(collision: Collider2D)
    }
}

package "Generación Procedural" {
    class RoomGenerator {
        - roomWidth: int
        - roomHeight: int
        - tilemap: Tilemap
        - wallTile: TileBase
        - floorTile: TileBase
        + GenerateRoom(): Room
        - CreateWalls()
        - CreateFloor()
        - CreateStairs()
    }

    class Room {
        - width: int
        - height: int
        - tiles: TileBase[][]
        - stairs: List<Stairs>
        - enemies: List<Enemy>
        + IsWalkable(x: int, y: int): bool
        + GetRandomWalkablePosition(): Vector2
    }

    class Stairs {
        - position: Vector2
        - isOpen: bool
        - targetRoom: Room
        + Open()
        + Close()
    }
}

package "Efectos de Tiles" {
    class TileEffect {
        - effectType: string
        - speedMultiplier: float
        - damageMultiplier: float
        + ApplyEffect(target: MonoBehaviour)
        + RemoveEffect(target: MonoBehaviour)
    }

    class FloorTileManager {
        - tileEffects: Dictionary<Vector2Int, TileEffect>
        - tilemap: Tilemap
        + GetTileEffectAt(position: Vector2): TileEffect
        + ApplyEffectToEnemy(enemy: Enemy, position: Vector2)
    }

    class DamageBoostManager {
        - activeTiles: Dictionary<int, TileEffect>
        + BoostDamage(source: Transform, multiplier: float): int
    }
}

package "Gestión de Juego" {
    class GameManager {
        - {static} instance: GameManager
        - currentRoom: Room
        - roomFlowController: RoomFlowController
        - gameState: GameState
        + {static} GetInstance(): GameManager
        + LoadRoom(roomIndex: int)
        + UnloadRoom()
        + GameOver()
        + Victory()
    }

    class RoomFlowController {
        - currentRoomIndex: int
        - totalRooms: int
        - bossIntervalRooms: int
        - bossCount: int
        - maxBosses: int
        + AdvanceToNextRoom()
        + IsBossRoom(): bool
        + IsGameWon(): bool
        - SpawnBoss()
    }

    class ScoreManager {
        - currentScore: int
        - highScores: List<int>
        + AddScore(amount: int)
        + SaveHighScore()
        + LoadHighScores(): List<int>
        + GetHighScores(): List<int>
    }

    enum GameState {
        MENU
        CLASS_SELECTION
        PLAYING
        PAUSED
        GAME_OVER
        VICTORY
    }
}

package "Interfaz de Usuario" {
    class MainMenuManager {
        - playButton: Button
        - quitButton: Button
        - highScoresUI: HighScoresUI
        + Start()
        + OnPlayClicked()
        + OnQuitClicked()
        + DisplayHighScores()
    }

    class ClassSelectionManager {
        - {static} SelectedClass: PlayerClass
        - classButtons: List<Button>
        - classData: List<PlayerClass>
        + SelectClass(classIndex: int)
        + {static} GetSelectedClass(): PlayerClass
    }

    class HealthUI {
        - heartPrefab: GameObject
        - heartsContainer: Transform
        - playerHealth: PlayerHealth
        + UpdateHealth(current: int, max: int)
        + UpdateHeartDisplay()
    }
}

package "Eventos" {
    class PersistentEventSystem {
        - {static} instance: PersistentEventSystem
        + {static} GetInstance(): PersistentEventSystem
        + OnEnemyDeath(enemy: Enemy)
        + OnPlayerDeath()
        + OnRoomCleared()
        + OnBossDefeated()
    }
}

PlayerController --> PlayerClass
PlayerController --> PlayerHealth
PlayerController --> Weapon
PlayerSpawner --> PlayerController

Enemy --> EnemyData
Enemy --> EnemyTileEffectReceiver
BossController --|> Enemy
EnemyManager --> Enemy
EnemyProjectileSpawner --> EnemyProjectile

Weapon --> WeaponData
MeleeWeapon --|> Weapon
RangedWeapon --|> Weapon
RangedWeapon --> Projectile

RoomGenerator --> Room
Room --> Stairs
Room --> Enemy
FloorTileManager --> TileEffect
DamageBoostManager --> TileEffect

GameManager --> Room
GameManager --> RoomFlowController
GameManager --> GameState
RoomFlowController --> BossController

MainMenuManager --> ClassSelectionManager
ClassSelectionManager --> PlayerClass
HealthUI --> PlayerHealth

PersistentEventSystem --> Enemy
PersistentEventSystem --> PlayerController
PersistentEventSystem --> BossController

@enduml
